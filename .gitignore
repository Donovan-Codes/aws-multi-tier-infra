# Terraform state (never commit these)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files with real values (never commit these)
terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files (local dev only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# OS junk
.DS_Store
Thumbs.db
